        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "AgencyPowerstack\\ContaoBlogSyncBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "AgencyPowerstack\\ContaoBlogSyncBundle\\ContaoManager\\Plugin"
    }
