{
    "name": "agencypowerstack/contao-blog-sync",
    "type": "contao-bundle",
    "description": "Automatische Blog-Synchronisation mit Agency Powerstack",
    "keywords": ["contao", "contao-bundle", "blog", "news", "sync", "agency-powerstack"],
    "homepage": "https://agency-powerstack.com",
    "license": "proprietary",
    "authors": [
        {
            "name": "Agency Powerstack",
            "homepage": "https://agency-powerstack.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/Agency-Powerstack/Contao-Blog-Sync/issues",
        "source": "https://github.com/Agency-Powerstack/Contao-Blog-Sync"
    },
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.0",
        "contao/news-bundle": "^5.0",
        "contao/manager-plugin": "^2.0",
        "symfony/framework-bundle": "^6.0 || ^7.0",
        "symfony/http-client": "^6.0 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "AgencyPowerstack\\ContaoBlogSyncBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "AgencyPowerstack\\ContaoBlogSyncBundle\\ContaoManager\\Plugin"
    }
}
